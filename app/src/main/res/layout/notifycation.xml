<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/notify_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon" />

    <TextView
        android:id="@+id/txt_noti_detail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="2dp"
        android:text="Details"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/txt_noti_des"
        app:layout_constraintStart_toEndOf="@+id/notify_logo"
        app:layout_constraintTop_toTopOf="@+id/notify_logo" />

    <TextView
        android:id="@+id/txt_noti_des"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Des"
        app:layout_constraintBottom_toBottomOf="@+id/notify_logo"
        app:layout_constraintStart_toStartOf="@+id/txt_noti_detail"
        app:layout_constraintTop_toBottomOf="@+id/txt_noti_detail" />
</androidx.constraintlayout.widget.ConstraintLayout>